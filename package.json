    "simple-git": "^3.22.0",
    "zod": "^3.22.4",
    "gray-matter": "^4.0.3",
    "vectra": "^0.4.0",
    "glob": "^10.3.10",
    "ignore": "^5.3.1",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "typescript": "^5.4.3",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.12.7",
    "@types/glob": "^8.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
